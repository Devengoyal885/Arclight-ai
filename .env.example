# Environment Variables for ArcLight AI 2.0
# Copy this file to .env.local and fill in your API keys

# ─── AI Keys ───────────────────────────────────────────────────────────────────

# Google Gemini (primary AI provider) — get keys at https://aistudio.google.com
# Comma-separated for key rotation
GEMINI_API_KEYS=your_gemini_api_key_here

# Groq (fast fallback — Llama 3.1) — get keys at https://console.groq.com
# Comma-separated for key rotation (supports key pools for high throughput)
GROQ_API_KEYS=your_groq_api_key_here

# OpenAI (final fallback) — get key at https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (optional) — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Data APIs ─────────────────────────────────────────────────────────────────

# World Air Quality Index — get token at https://aqicn.org/api/
WAQI_TOKEN=your_waqi_token_here

# Open-Meteo does NOT require an API key for the free tier
# No setup needed — data fetches work out of the box!

# ─── Optional / Future ─────────────────────────────────────────────────────────

# Mapbox (for interactive maps)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# DeepSeek (alternative LLM provider)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
